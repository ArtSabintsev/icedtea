  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#78828B"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#86D38B"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "support.constant"
      ],
      "settings": {
        "foreground": "#D7B866"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C997E8"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#F0C76A"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#82B7E8"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.enum",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#78D0C8"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#9CCBFF"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#ECE6DA"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#D7DEE3"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#DDB5F7"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#E66F6F"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#F3F0E8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FFF2C2",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#ECE6DA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#E66F6F"
      }
    },
    {
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#86D38B"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#D7B866"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#78D0C8",
    "decorator": "#C997E8",
    "enum": "#78D0C8",
    "enumMember": "#D7B866",
    "function": "#82B7E8",
    "interface": "#78D0C8",
    "method": "#82B7E8",
    "namespace": "#78D0C8",
    "parameter": "#D7DEE3",
    "property": "#ECE6DA",
    "type": "#78D0C8",
    "typeParameter": "#78D0C8",
    "variable.readonly": "#D7B866"
  }
}
