  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8A919A"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#84D88B"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "support.constant"
      ],
      "settings": {
        "foreground": "#EFD66B"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D49BFF"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#F6C96D"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#84BFFF"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.enum",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#70D6D0"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#A6D2FF"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#E8E1D4"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#D7DCE2"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#E1B7FF"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF7A7A"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#F4F1E8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FFF1C2",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#E8E1D4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#FF7A7A"
      }
    },
    {
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#84D88B"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#EFD66B"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#70D6D0",
    "decorator": "#D49BFF",
    "enum": "#70D6D0",
    "enumMember": "#EFD66B",
    "function": "#84BFFF",
    "interface": "#70D6D0",
    "method": "#84BFFF",
    "namespace": "#70D6D0",
    "parameter": "#D7DCE2",
    "property": "#E8E1D4",
    "type": "#70D6D0",
    "typeParameter": "#70D6D0",
    "variable.readonly": "#EFD66B"
  }
}
